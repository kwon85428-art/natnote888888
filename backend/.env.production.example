# =============================================================================
# NavNote 后端环境变量 — 生产模板
# =============================================================================
# 用法：cp .env.production.example .env，编辑后启动
# 详解：docs/CONFIGURATION.md、deploy/README.md
# 启停：./service.sh start prod
# =============================================================================

# --- 应用与安全（生产必填）---

APP_NAME=NavNote

# 必填：openssl rand -hex 32 生成；DEBUG=false 时不可为占位值
SECRET_KEY=请替换为-openssl-rand-hex-32-生成的随机串

# 生产务必 false（关闭 /docs）
DEBUG=false

# JWT 算法，一般无需修改
# JWT_ALGORITHM=HS256

# 登录 Token 有效期（分钟）
# ACCESS_TOKEN_EXPIRE_MINUTES=120

# 空库首次创建 admin；部署后立即在后台改密
INITIAL_ADMIN_PASSWORD=请替换为强密码至少8位

# 前后端分域时填写 Origin；同源 Nginx 反代 /api 时留空
# CORS_ORIGINS=

# --- 数据库（生产必填 MySQL）---

DATABASE_URL=mysql+pymysql://navnote:数据库密码@127.0.0.1:3306/navnote?charset=utf8mb4

# SQLite 仅适合单进程调试，勿用于生产：
# DATABASE_URL=sqlite:///./data/navnote.db

# --- 访问统计与文件日志 ---

STATS_FLUSH_INTERVAL_SECONDS=30
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5

# --- 上传大小上限（字节）---
# UPLOAD_MAX_BYTES_LOGO=5242880
# UPLOAD_MAX_BYTES_COVER=8388608
# UPLOAD_MAX_BYTES_ARTICLE_BODY=8388608

REMOTE_FETCH_VERIFY_SSL=true

# --- SEO（生产强烈建议填写）---

# sitemap / robots 绝对链接的根 URL，如 https://www.example.com
PUBLIC_SITE_URL=https://你的域名

# --- 进程参数 ---

# 生产推荐 gunicorn（./service.sh start prod 会自动设置）
# NAVNOTE_SERVER=gunicorn
# GUNICORN_BIND=127.0.0.1:8000
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=120
# GUNICORN_GRACEFUL_TIMEOUT=30
# GUNICORN_KEEPALIVE=5
# GUNICORN_PRELOAD=false
# GUNICORN_LOG_LEVEL=info
# GUNICORN_ACCESS_LOG=-
# GUNICORN_ERROR_LOG=-

# UVICORN_HOST=127.0.0.1
# UVICORN_PORT=8000
# UVICORN_WORKERS=1
