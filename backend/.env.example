# =============================================================================
# NavNote 后端环境变量 — 本地开发模板
# =============================================================================
# 用法：cp .env.example .env
# 详解：docs/CONFIGURATION.md、backend/README.md
# 启停：./service.sh start dev
# =============================================================================

# --- 应用与安全 ---

# 应用显示名称（页面标题后缀等）
APP_NAME=NavNote

# JWT 签名密钥。开发可随意填写；生产必须用随机长串（openssl rand -hex 32）
SECRET_KEY=change-me-in-production-use-long-random-string

# true=开放 /docs 调试接口；生产务必 false
DEBUG=true

# JWT 算法，一般无需修改
# JWT_ALGORITHM=HS256

# 管理员登录 Token 有效期（分钟），范围 5～43200
# ACCESS_TOKEN_EXPIRE_MINUTES=120

# 空库首次启动时创建 admin 账号的密码（至少 8 位）；登录后请尽快改密
INITIAL_ADMIN_PASSWORD=admin123456

# 前后端分域时填写前端 Origin，逗号分隔
# 同源开发（Vite 代理 /api）时留空
# CORS_ORIGINS=https://www.example.com

# --- 数据库 ---

# SQLite：单进程，适合本地开发；路径相对 backend/ 目录
DATABASE_URL=sqlite:///./data/navnote.db

# MySQL：生产推荐（见 deploy/README.md）
# DATABASE_URL=mysql+pymysql://navnote:pass@127.0.0.1:3306/navnote?charset=utf8mb4

# --- 访问统计与文件日志 ---

# PV / 点击计数批量落库间隔（秒）
STATS_FLUSH_INTERVAL_SECONDS=30

# 滚动日志单文件上限（字节）、保留份数（目录 backend/data/logs/）
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5

# --- 上传大小上限（字节，未设置则用代码默认值）---

# Logo 上传上限，默认 5242880（5MB）
# UPLOAD_MAX_BYTES_LOGO=5242880

# 文章封面上限，默认 8388608（8MB）
# UPLOAD_MAX_BYTES_COVER=8388608

# 正文内嵌图片上限，默认 8388608（8MB）
# UPLOAD_MAX_BYTES_ARTICLE_BODY=8388608

# 抓取远程 favicon / 封面时是否校验 HTTPS 证书
REMOTE_FETCH_VERIFY_SSL=true

# --- SEO ---

# 站点根 URL，用于 sitemap.xml / robots.txt 中的绝对链接
# 开发一般留空；测试 sitemap 可设 http://127.0.0.1:8000
# PUBLIC_SITE_URL=https://navnote.example.com

# --- 进程参数（见 backend/README.md）---
# NAVNOTE_SERVER=uvicorn

# Gunicorn 监听地址（生产模式）
# GUNICORN_BIND=127.0.0.1:8000
# GUNICORN_HOST=127.0.0.1
# GUNICORN_PORT=8000

# Worker 数量；SQLite 强制为 1，MySQL 可 >1
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=120
# GUNICORN_GRACEFUL_TIMEOUT=30
# GUNICORN_KEEPALIVE=5
# GUNICORN_PRELOAD=false
# GUNICORN_LOG_LEVEL=info
# GUNICORN_ACCESS_LOG=-
# GUNICORN_ERROR_LOG=-

# Uvicorn 监听（开发 / 单进程模式）
# UVICORN_HOST=127.0.0.1
# UVICORN_PORT=8000
# UVICORN_WORKERS=1
